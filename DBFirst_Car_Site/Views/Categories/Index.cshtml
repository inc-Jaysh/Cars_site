@model IEnumerable<DBFirst_Car_Site.Models.Category>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

@if (TempData["AlertMessage"] != null)
{
    <script>
        alert('@Html.Raw(TempData["AlertMessage"])');
    </script>
}

<form data-ajax="true" data-ajax-method="post" data-ajax-url="/Categories/CatList" data-ajax-update="#results" data-ajax-confirm="Are you sure?">
    <input type="text" name="searchText" />
    <input type="submit" value="Поиск" />
</form>

<p>
    <a asp-action="Create">Create New</a>
</p>
<div id="results">
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Title)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MaxSeats)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Title)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MaxSeats)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
</div>